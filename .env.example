# Copier vers .env et adapter. Le fichier .env n'est JAMAIS committé (invariant I2).

# --- Application ---
APP_ENV=dev                # dev | staging | prod
LOG_LEVEL=INFO
VALKEY_URL=redis://localhost:6379/0

# --- PostgreSQL (le rôle peut CREATE DATABASE : requis par le provisioning de tenants) ---
# En local : le Postgres du Compose (localhost). En conteneur : POSTGRES_HOST=postgres.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=controlplane

# --- Multi-tenant ---
# Le catalogue ne stocke jamais d'URL ni de credentials : tout est composé depuis ces variables.
TENANT_DB_PREFIX=tenant_
TENANT_ENGINE_CACHE_SIZE=20
TENANT_ENGINE_POOL_SIZE=2

# --- Auth (Phase 2) ---
# Clé maître AES-256 en base64 (32 octets décodés) : `openssl rand -base64 32`.
# OBLIGATOIRE hors dev (chiffre les secrets TOTP, signe les states OAuth).
AUTH_MASTER_KEY=
SESSION_TTL_HOURS=168
SESSION_COOKIE_NAME=saas_session
# Domaine du cookie de session (décision D2) : `.staging.example.fr` en staging
# pour partager la session entre sous-domaines tenant ; vide = host-only (dev).
SESSION_COOKIE_DOMAIN=
# URL publique apex (callbacks OAuth, liens d'invitation), ex. https://staging.example.fr
PUBLIC_BASE_URL=http://localhost:8000
INVITATION_TTL_HOURS=168

# --- OAuth login Google / Microsoft (scopes openid email profile uniquement) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Connecteurs externes (Phase 5) — apps OAuth DISTINCTES du login (décision D3) ---
# Google : scopes gmail.readonly/gmail.send/calendar ; redirect .../connectors/google/callback
# Microsoft : Mail.Read/Mail.Send/Calendars.ReadWrite/offline_access ; .../connectors/microsoft/callback
GOOGLE_CONNECTOR_CLIENT_ID=
GOOGLE_CONNECTOR_CLIENT_SECRET=
MICROSOFT_CONNECTOR_CLIENT_ID=
MICROSOFT_CONNECTOR_CLIENT_SECRET=
# Avance du refresh proactif sur l'expiration des access tokens (minutes).
CONNECTOR_REFRESH_LEAD_MINUTES=10
# Base publique des webhooks entrants ; vide = PUBLIC_BASE_URL.
CONNECTOR_WEBHOOK_BASE_URL=

# --- Emails transactionnels (décision D8 : optionnel — l'URL d'invitation est
# toujours retournée à l'appelant ; SMTP vide = aucun envoi) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=

# --- Rate limiting auth (fenêtre fixe sur Valkey, décision D9) ---
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# --- Audit + RGPD (Phase 4) ---
AUDIT_RETENTION_DAYS=365
# Volume dédié (voir docker-compose.yml `gdpr_exports`) — jamais servi par la surface publique.
GDPR_EXPORT_DIR=/var/lib/saas/gdpr-exports
GDPR_EXPORT_TTL_DAYS=7
GDPR_ERASURE_GRACE_DAYS=7

# --- Caddy ---
# Dev : http://localhost:8080 — Staging : le domaine (TLS automatique)
SITE_ADDRESS=http://localhost:8080
# Back-office (Phase 3) : jamais l'apex public — un hôte interne, joignable uniquement
# via WireGuard/tunnel SSH en staging (invariant I6/I7). Dev : http://localhost:8081.
ADMIN_SITE_ADDRESS=http://localhost:8081

# --- Grafana (surface admin, jamais exposée publiquement — invariant I6) ---
GRAFANA_ADMIN_PASSWORD=change-me

# --- Images ---
# Dev : builds locaux. Staging : tags GHCR :latest, tirés par scripts/deploy-pull.sh
# (ex. API_IMAGE=ghcr.io/<owner>/<repo>-api:latest)
API_IMAGE=saas-api:local
WEB_IMAGE=saas-web:local
ADMIN_IMAGE=saas-admin:local
