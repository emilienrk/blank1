{
  "name": "@app/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client TS GÉNÉRÉ depuis l'OpenAPI du backend — ne jamais éditer src/schema.ts à la main",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "openapi-typescript ../../openapi.json -o src/schema.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
